# OpenAI API 兼容服务（仅服务端读取）
# 项目优先读取下列简写变量；同时兼容 OPENAI_API_KEY、OPENAI_BASE_URL、OPENAI_MODEL。
API_KEY=sk-your-key
BASE_URL=https://api.openai.com/v1
MODEL=gpt-5-mini
OPENAI_TIMEOUT_MS=90000
DATA_DIR=./data

# Demo 登录。默认值为 user / test；部署前务必修改密码与随机会话密钥。
AUTH_USERNAME=user
AUTH_PASSWORD=test
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters

# 公网部署建议显式填写站点唯一外部地址（不要以 / 结尾），用于同源请求校验。
# APP_ORIGIN=https://agent.example.com

# 仅当应用位于会清洗并重写 X-Forwarded-* 的可信反向代理后方时设为 1。
TRUST_PROXY=0
